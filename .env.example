# BlueCairn — environment variables
# Copy to .env.local for local development. Never commit .env.local.
# Production values live in 1Password/Doppler, not in any file.

# -----------------------------------------------------------------------------
# Database — Neon Postgres
# -----------------------------------------------------------------------------
# Use the `bluecairn_app` role (no bypassrls). Use `bluecairn_admin` only for migrations.
DATABASE_URL=postgresql://bluecairn_app:PASSWORD@ep-xxxxx.us-west-2.aws.neon.tech/bluecairn?sslmode=require

# Separate URL for migrations (admin role)
DATABASE_URL_ADMIN=postgresql://bluecairn_admin:PASSWORD@ep-xxxxx.us-west-2.aws.neon.tech/bluecairn?sslmode=require

# -----------------------------------------------------------------------------
# Redis — Upstash
# -----------------------------------------------------------------------------
REDIS_URL=rediss://default:PASSWORD@xxxxx.upstash.io:6379

# -----------------------------------------------------------------------------
# Telegram (primary channel for MVP, per ADR-0009)
# -----------------------------------------------------------------------------
# Obtain from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAFakeTokenFromBotFather
# Random secret you generate; Telegram sends it in webhook headers for auth
TELEGRAM_WEBHOOK_SECRET=generate-a-random-32-char-string

# -----------------------------------------------------------------------------
# Langfuse (self-hosted LLM observability)
# -----------------------------------------------------------------------------
LANGFUSE_HOST=https://langfuse.bluecairn.internal
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxx

# -----------------------------------------------------------------------------
# LLM providers (via Vercel AI SDK abstraction)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GOOGLE_GENERATIVE_AI_API_KEY=xxxxx

# -----------------------------------------------------------------------------
# Inngest (durable execution)
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=xxxxx
INNGEST_SIGNING_KEY=signkey-xxxxx

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Orchestrator feature flag (BLU-19). When false, the Telegram webhook skips
# the Inngest event emit and reverts to the M0 inline persist-only behavior.
ORCHESTRATOR_ENABLED=true
