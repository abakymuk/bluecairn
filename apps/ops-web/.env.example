# apps/ops-web — local dev env template. Copy to .env.local and fill.
# Production values live in Doppler (`dev`, `stg` configs). 1Password
# holds the Google OAuth client secret + Better Auth secret.

# --- Database (shared with the rest of the monorepo) ---
DATABASE_URL=postgresql://bluecairn_app:PASSWORD@HOST/bluecairn?sslmode=require
DATABASE_URL_ADMIN=postgresql://bluecairn_admin:PASSWORD@HOST/bluecairn?sslmode=require

# --- Better Auth ---
# Generate: openssl rand -base64 48 | tr -d '\n' | cut -c1-48
BETTER_AUTH_SECRET=replace-with-48-char-secret-from-1password

# Base URL Better Auth uses for OAuth callbacks. Match the port in
# apps/ops-web/package.json (3002 by default).
BETTER_AUTH_URL=http://localhost:3002

# --- Google OAuth (Cloud Console → APIs & Services → Credentials) ---
# Create an "OAuth 2.0 Client ID" of type "Web application". Add these
# Authorized redirect URIs:
#   - http://localhost:3002/api/auth/callback/google          (dev)
#   - https://ops-web-staging-XXXX.up.railway.app/api/auth/callback/google  (stg)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# --- Email allow-list ---
# Comma-separated list of Google emails allowed to sign in. All other
# emails reach /threads but see a 403 panel.
OPS_WEB_ALLOWED_EMAILS=vlad@example.com,nick@example.com
