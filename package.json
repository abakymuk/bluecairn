{
  "name": "bluecairn",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Operational partner for independent restaurants, delivered through chat.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "eval": "turbo run eval",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "cd packages/db && bun --bun drizzle-kit generate",
    "db:push": "cd packages/db && bun --bun drizzle-kit push",
    "db:studio": "cd packages/db && bun --bun drizzle-kit studio",
    "db:bootstrap": "cd packages/db && bun run scripts/bootstrap-internal-tenant.ts",
    "harness:m1": "bun run --cwd packages/evals harness:m1",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/bun": "^1.2.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.15.0",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.2.0"
}
